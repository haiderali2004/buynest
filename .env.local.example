# =========================================================
# BuyNest — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit the filled-in .env.local file.
# =========================================================

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, bypasses RLS — never expose to the client

# --- Database (Project Settings -> Database -> Connection string) ---
# Supabase enforces TLS on both of these endpoints server-side — the
# connection is encrypted whether or not the string says so explicitly.
# Pooled connection, used by the app at runtime (PgBouncer, port 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true
# Direct connection, used only for running Prisma migrations (port 5432)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# --- Safepay (Dashboard -> Developers -> API keys) ---
# Get these from https://getsafepay.com/dashboard (production) or
# https://sandbox.api.getsafepay.com/dashboard (sandbox) after Safepay
# approves your merchant KYC application.
SAFEPAY_ENV=sandbox   # "sandbox" or "production"
SAFEPAY_SECRET_KEY=sec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SAFEPAY_API_KEY=sec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SAFEPAY_WEBHOOK_SECRET=your-webhook-shared-secret   # Dashboard -> Developers -> Endpoints -> View shared secret
# CYBERSOURCE or MPGS — whichever processor your merchant account is
# actually provisioned with. Confirm with Safepay if unsure.
SAFEPAY_INTENT=CYBERSOURCE

# --- Resend (Dashboard -> API Keys) ---
# https://resend.com/api-keys — free tier covers 3,000 emails/month.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be on a domain you've verified in Resend's dashboard before this
# will deliver to real customer inboxes — until then, sends only land in
# the inbox you signed up to Resend with (their test-mode behavior).
EMAIL_FROM=BuyNest <orders@yourdomain.com>

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cron (optional but recommended in production — see app/api/cron/release-reservations) ---
CRON_SECRET=generate-a-long-random-string-here
